{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Claude Workbench",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-mkdir",
    "fs:allow-watch",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "$CWD/**" }, { "path": "$RESOURCE/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$CWD/**" }]
    }
  ]
}
